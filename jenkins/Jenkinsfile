pipeline {
    agent any 

    // def getServices() {
    //     return [
    //     [name: 'api-gateway', dir: 'api-gateway'],
    //     [name: 'user-service', dir: 'user-services'],
    //     [name: 'product-service', dir: 'product-services'],
    //     [name: 'order-service', dir: 'order-services'],
    //     [name: 'notification-service', dir: 'notification-services']
    // ]
    // }

    environment {
        AWS_REGION      =   "ap-south-1"
        ECR_REGISTRY    =   "066606187609.dkr.ecr.ap-south-1.amazonaws.com"
        PROJECT_NAME    =   "secureflow"
        APP_SERVER_IP   =   "10.0.1.235"
        CLUSTER_NAME    =   "secureflow"
        APP_HOME        =   "/home/ubuntu/SecureFlow"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Code checked out from ${env.GIT_BRANCH}"
            }
        }

        stage('Bandit') {
            steps {
                sh '''
                  export PATH=$PATH:/var/lib/jenkins/.local/bin
                  pip3 install bandit --quiet
                  echo "Running Bandit scan"

                  bandit -r services/ -f json -o bandit-report.json --severity-level medium || true

                  echo "Bandit scan complete"
                '''
            }

            post {
                always {
                    archiveArtifacts artifacts: 'bandit-report.json', allowEmptyArchive: true
                }
            }
        }

        stage('Gitleaks Secret Scan') {
         steps {
            sh '''
              echo "Running Gitleaks secret scan..."

              # Create a local directory in jenkins workspace
              mkdir -p $HOME/bin


              #Install gitleaks if not present

              if ! command -v gitleaks &> /dev/null; then
                echo "Installing gitleaks..."

                curl -sSL https://github.com/gitleaks/gitleaks/releases/download/v8.18.2/gitleaks_8.18.2_linux_x64.tar.gz \
                | tar -xz -C $HOME/bin gitleaks
                
                chmod +x $HOME/bin/gitleaks
              fi

               export PATH="$HOME/bin/:$PATH"

               gitleaks detect --source . --report-format json --report-path gitleaks-report.json --exit-code 1
            '''
        }

        post {
            always {
                archiveArtifacts artifacts: 'gitleaks-report.json', allowEmptyArchive: true
            }

            failure {
                error "Gitleaks found secret in codebase. Pipeline stopped"
            }
        }
    }

        stage('Safety Dependency Scan') {
        steps {
            sh '''
              pip3 install --user "safety==2.3.5" --quiet
              export PATH=$PATH:$(python3 -m site --user-base)/bin

              echo "Running safety dependency scan"

              for service in user-services product-services order-services api-gateway notification-services; do
                echo "Scanning $service dependencies..."
                
                python3 -m safety check -r services/$service/requirements.txt --output json > safety-$service-report.json || true
              done

              echo "Dependency scan complete"
            '''
        }

        post {
            always {
                archiveArtifacts artifacts: 'safety-*-report.json', allowEmptyArchive: true
            }
        }
    }

        stage('Docker Build') {
        steps {
                script {
                    def services = [
                        'api-gateway',
                        'user-service',
                        'product-service',
                        'order-service',
                        'notification-service'
                    ]

                    def serviceDirs = [
                        'api-gateway'          : 'api-gateway',
                        'user-service'         : 'user-services',
                        'product-service'      : 'product-services',
                        'order-service'        : 'order-services',
                        'notification-service' : 'notification-services'
                    ]

                    env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    echo "Building images with tag: ${env.GIT_SHA}"
                    sh "aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 066606187609.dkr.ecr.ap-south-1.amazonaws.com"

                    services.each { service ->
                        def dir = serviceDirs[service]
                        sh """
                            docker build \
                                -t ${ECR_REGISTRY}/${PROJECT_NAME}/${service}:${env.GIT_SHA} \
                                -t ${ECR_REGISTRY}/${PROJECT_NAME}/${service}:latest \
                                ./services/${dir}
                        """
                        echo "Built ${service}"
                    }
                }
            }
    }

        stage('Trivy Scan Image') {
        steps {
            script {
                def services = [
                        'api-gateway',
                        'user-service',
                        'product-service',
                        'order-service',
                        'notification-service'
                    ]

                // Install trivy if not present
                sh '''
                  mkdir -p "$HOME/bin"

                  if ! command -v trivy &> /dev/null; then
                    echo "Installing Trivy..."
                            curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh \
                                | sh -s -- -b "$HOME/bin"
                  fi

                  export PATH="$HOME/bin:$PATH"
                  trivy --version
                '''

                services.each { service ->
                        sh """
                            export PATH="\$HOME/bin:\$PATH"

                            echo "Scanning ${service}..."

                            trivy image \
                                --quiet \
                                --format json \
                                --output trivy-${service}-report.json \
                                --severity LOW,MEDIUM,HIGH,CRITICAL \
                                --exit-code 0 \
                                ${ECR_REGISTRY}/${PROJECT_NAME}/${service}:${env.GIT_SHA}

                            echo "${service} passed Trivy scan"
                        """
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'trivy-*-report.json', allowEmptyArchive: true

        }
        
        }
    }

        stage('Push to ECR') {
        steps {
            script {
                sh """
                  echo "Login to ECR"

                  aws ecr get-login-password --region ${AWS_REGION} | \
                  docker login --username AWS --password-stdin ${ECR_REGISTRY}
                """

                def services = [
                            'api-gateway',
                            'user-service',
                            'product-service',
                            'order-service',
                            'notification-service'
                        ]

                services.each { service ->
                            sh """
                                echo "Pushing ${service}..."
                                docker push ${ECR_REGISTRY}/${PROJECT_NAME}/${service}:${env.GIT_SHA}
                                docker push ${ECR_REGISTRY}/${PROJECT_NAME}/${service}:latest
                                echo "Pushed ${service}"
                            """
                }
            }
        }
    }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    withCredentials([sshUserPrivateKey(
                        credentialsId: 'app-server-ssh',
                        keyFileVariable: 'SSH_KEY',
                        usernameVariable: 'SSH_USER'
                        ),
                        file(credentialsId: 'app-secrets-file', variable: 'APP_SECRETS')]) {
                            sh """
                                echo "Deploying to Kubernetes cluster..."

                                ssh -i \$SSH_KEY \
                                    -o StrictHostKeyChecking=no \
                                    -o ConnectTimeout=30 \
                                    \$SSH_USER@${APP_SERVER_IP} \
                                    'set -e
                                    echo "Connected to app server"
                                    echo "Current user: \$(whoami)"
                                    echo "Home dir: \$(echo \$HOME)"
                                    if [ -d "/home/ubuntu/SecureFlow/.git" ]; then
                                        echo "Repo exists, pulling latest changes..."
                                        cd /home/ubuntu/SecureFlow
                                        git pull origin main

                                    else
                                        echo "Repo not found, cloning..."
                                        git clone https://https://github.com/amandev-x/SecureFlow.git /home/ubuntu/SecureFlow
                                    fi'
                                    scp -i \$SSH_KEY -o StrictHostKeyChecking=no \$APP_SECRETS \
                                      \$SSH_USER@${APP_SERVER_IP}:/home/ubuntu/SecureFlow/k8s/secrets/app-secret.yml
                                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${SSH_USER}@${APP_SERVER_IP} \
                                    "set -e
                                    aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                                    # create ECR pull secret
                                    cd /home/ubuntu/SecureFlow
                                    GIT_SHA=\$(git rev-parse --short HEAD)
                                    echo "Deploying Version: \$GIT_SHA"
                                    find k8s/ -name "deployment*.yml" -type f -exec sed -i "s|:latest|:$GIT_SHA|g" {} +
                                    kubectl apply -f k8s/namespace.yml
                                    kubectl create secret docker-registry ecr-secret \
                                    --docker-server=${ECR_REGISTRY} \
                                    --docker-username=AWS \
                                    --docker-password=\$(aws ecr get-login-password --region ap-south-1) \
                                    --namespace=secureflow \
                                    --dry-run=client -o yaml | kubectl apply -f -
                                    kubectl apply -f k8s/secrets/app-secret.yml
                                    kubectl apply -f k8s/rbac/
                                    kubectl apply -f k8s/network-policies/
                                    kubectl apply -f k8s/user-service/
                                    kubectl apply -f k8s/product-service/
                                    kubectl apply -f k8s/order-service/
                                    kubectl apply -f k8s/notification-service/
                                    kubectl apply -f k8s/api-gateway/
                                    kubectl apply -f k8s/ingress.yml
                                    find k8s/ -name "deployment*.yml" -type f -exec sed -i "s|:$GIT_SHA|:latest|g" {} +
                                    for deploy in api-gateway-deployment user-service-deployment product-service-deployment order-service-deployment notification-service-deployment notification-worker-deployment; do
                                        kubectl rollout status deployment/\$deploy -n secureflow --timeout=120s
                                    done
                                    echo 'Deployment complete'"
                                """
                                }
                        }
            }
        post {
            failure {
                echo "Deployment to Kubernetes failed"
                }
            success {
                echo "Successfully deployed to Kubernetes"
                }
                }
                }

        stage('Health Check') {
        steps {
            sh """
              echo "🔍 Running health checks..."
              sleep 10

              for i in 1 2 3 4 5; do 
                STATUS=\$(curl -s -o /dev/null -w "%{http_code}" http://${APP_SERVER_IP}:/health)

                if [ "\$STATUS" = "200" ]; then 
                  echo "Health check passed. Api gateway is up"
                  exit 0
                fi 

                echo "Attempt \$i failed (status: \$STATUS), retrying in 10s..."
                sleep 5
              done

              echo "Health check failed after 5 attempts"
              exit 1
            """
        }
    }
}

// ── Post Pipeline ──────────────────────────────────────────────────────
    post {
        success {
            echo """
             Pipeline completed successfully!
            ─────────────────────────────────
            Branch  : ${env.GIT_BRANCH}
            Commit  : ${env.GIT_SHA}
            App URL : http://${APP_SERVER_IP}:8000
            """
        }
        failure {
            echo " Pipeline failed — check logs above"
        }
        always {
            // clean up Docker images to save disk space
            sh """
                docker image prune -f || true
            """
        }
    }
}
